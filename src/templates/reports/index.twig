{#
 # Reports Index - Using cp-table layout
 #
 # Lists all reports with filtering, sorting, bulk actions and pagination.
 # Filters/sort/paginate are owned by ReportsController::actionIndex.
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# ============================================================================
   BUILD FILTER OPTIONS
   ============================================================================ #}

{# Build format options from enabled exports config. #}
{% set formatOptions = [{value: 'all', label: 'All Formats'|t('report-manager'), status: 'all'}] %}
{% for format in lrExportFormatOptions() %}
    {% set formatOptions = formatOptions|merge([{value: format.value, label: format.label, colorKey: format.value}]) %}
{% endfor %}

{# ============================================================================
   TABLE CONFIGURATION
   ============================================================================ #}

{% set tableConfig = {
    plugin: {
        handle: 'report-manager',
        name: reportHelper.fullName,
    },
    page: {
        title: 'Reports'|t('report-manager'),
        subnav: 'reports',
        crumbs: [
            { label: reportHelper.fullName, url: url('report-manager') },
            { label: 'Reports'|t('report-manager') }
        ],
    },
    filters: [
        {
            type: 'status',
            param: 'status',
            current: statusFilter,
            label: 'All'|t('report-manager'),
            groups: [
                {
                    param: 'status',
                    current: statusFilter,
                    colorSet: 'status',
                    options: [
                        {value: 'all', label: 'All'|t('report-manager'), status: 'all'},
                        {value: 'enabled', label: 'Enabled'|t('report-manager'), colorKey: 'enabled'},
                        {value: 'disabled', label: 'Disabled'|t('report-manager'), colorKey: 'disabled'},
                    ],
                },
                {
                    header: 'Format'|t('report-manager'),
                    param: 'format',
                    current: formatFilter,
                    colorSet: 'exportFormat',
                    options: formatOptions,
                },
            ],
        },
    ],
    search: {
        placeholder: 'Search reports...'|t('report-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: [
            {key: 'name', label: 'Name'|t('report-manager'), sortable: true},
            {key: 'dataSource', label: 'Source'|t('report-manager'), sortable: true, hideable: true},
            {key: 'mode', label: 'Mode'|t('report-manager'), hideable: true},
            {key: 'exportFormat', label: 'Format'|t('report-manager'), sortable: true, hideable: true},
            {key: 'generatedFiles', label: 'Files'|t('report-manager'), hideable: true},
            {key: 'schedule', label: 'Schedule'|t('report-manager'), hideable: true},
            {key: 'lastGeneratedAt', label: 'Last Run'|t('report-manager'), sortable: true, hideable: true},
            {key: 'nextScheduledAt', label: 'Next Run'|t('report-manager'), sortable: true, hideable: true},
            {key: 'enabled', label: 'Status'|t('report-manager'), sortable: true},
        ],
        items: reports,
        emptyMessage: 'No reports found.'|t('report-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'report'|t('report-manager'), plural: 'reports'|t('report-manager')},
    },
    checkboxes: canEdit or canDelete,
    newButton: canEdit ? {
        url: url('report-manager/reports/new'),
        label: 'New Report'|t('report-manager'),
    } : null,
} %}


{# ============================================================================
   CUSTOM TABLE ROW RENDERING
   ============================================================================ #}

{% block tableRow %}
    {# Name #}
    <td data-column="name">
        {% if canEdit %}
            <a href="{{ url('report-manager/reports/' ~ item.id) }}">{{ item.name }}</a>
        {% else %}
            {{ item.name }}
        {% endif %}
    </td>

    {# Source #}
    <td data-column="dataSource" class="lr-hideable-column">{{ dataSources[item.dataSource].name ?? item.dataSource|capitalize }}</td>

    {# Mode #}
    <td data-column="mode" class="lr-hideable-column">{{ item.exportMode == 'combined' ? 'Combined'|t('report-manager') : 'Separate'|t('report-manager') }}</td>

    {# Format #}
    <td data-column="exportFormat" class="lr-hideable-column">
        {% include 'lindemannrock-base/_components/badge' with {
            label: item.exportFormat|upper,
            value: item.exportFormat,
            colorSet: 'exportFormat',
        } only %}
    </td>

    {# Generated Files #}
    <td data-column="generatedFiles" class="lr-hideable-column">
        {% set exportCount = exportCounts[item.id] ?? 0 %}
        {% if exportCount > 0 and canViewGenerated %}
            <a href="{{ url('report-manager/reports/' ~ item.id ~ '/generated') }}">{{ exportCount|number_format }}</a>
        {% elseif exportCount > 0 %}
            {{ exportCount|number_format }}
        {% else %}
            <span class="light">0</span>
        {% endif %}
    </td>

    {# Schedule #}
    <td data-column="schedule" class="lr-hideable-column">
        {% if not settings.enableScheduledReports %}
            <span class="light">{{ 'Disabled'|t('report-manager') }}</span>
        {% elseif item.enableSchedule %}
            {{ item.scheduleLabel }}
        {% else %}
            <span class="light">{{ 'Manual'|t('report-manager') }}</span>
        {% endif %}
    </td>

    {# Last Run #}
    <td data-column="lastGeneratedAt" class="light lr-hideable-column">
        {% if item.lastGeneratedAt %}
            {{ item.lastGeneratedAt|lrCompactDatetime }}
        {% else %}
            {{ 'Never'|t('report-manager') }}
        {% endif %}
    </td>

    {# Next Run #}
    <td data-column="nextScheduledAt" class="light lr-hideable-column">
        {% if settings.enableScheduledReports and item.enableSchedule and item.nextScheduledAt %}
            {{ item.nextScheduledAt|lrCompactDatetime }}
        {% else %}
            <span class="light">-</span>
        {% endif %}
    </td>

    {# Status #}
    <td data-column="enabled">
        {% include 'lindemannrock-base/_components/badge' with {
            label: item.enabled ? 'Enabled'|t('report-manager') : 'Disabled'|t('report-manager'),
            value: item.enabled ? 'enabled' : 'disabled',
            colorSet: 'status',
        } only %}
    </td>
{% endblock %}


{# ============================================================================
   ROW ACTIONS
   ============================================================================ #}

{% block rowActions %}
    {% set actionItems = [] %}

    {% if canEdit %}
        {% set actionItems = actionItems|merge([{
            label: 'Edit'|t('report-manager'),
            url: url('report-manager/reports/' ~ item.id),
        }]) %}
    {% endif %}

    {% if canViewGenerated %}
        {% set actionItems = actionItems|merge([{
            label: 'View Generated'|t('report-manager'),
            url: url('report-manager/reports/' ~ item.id ~ '/generated'),
        }]) %}
    {% endif %}

    {% if canGenerate %}
        {% set actionItems = actionItems|merge([
            {type: 'divider'},
            {
                label: 'Generate Now'|t('report-manager'),
                jsAction: 'generate',
                data: {name: item.name},
            },
        ]) %}
    {% endif %}

    {% if canDelete %}
        {% set actionItems = actionItems|merge([
            {type: 'divider'},
            {
                label: 'Delete'|t('report-manager'),
                class: 'error',
                jsAction: 'delete',
                data: {name: item.name},
            },
        ]) %}
    {% endif %}

    {% include 'lindemannrock-base/_components/row-actions' with {
        item: item,
        actions: {
            type: 'menu',
            icon: 'settings',
            title: 'Actions'|t('report-manager'),
            items: actionItems,
        },
    } only %}
{% endblock %}


{# ============================================================================
   BULK ACTIONS
   ============================================================================ #}

{% block bulkActions %}
    {% if canEdit %}
        <div>
            <button type="button" class="btn menubtn secondary" id="lr-bulk-status-btn" aria-label="{{ 'Set status'|t('report-manager') }}">
                {{ 'Set status'|t('report-manager') }}
            </button>
            <div class="menu">
                <ul>
                    <li><a id="lr-bulk-enable-action">{{ 'Enable'|t('report-manager') }}</a></li>
                    <li><a id="lr-bulk-disable-action">{{ 'Disable'|t('report-manager') }}</a></li>
                </ul>
            </div>
        </div>
    {% endif %}
    {% if canDelete %}
        <button type="button" class="btn secondary" id="lr-bulk-delete-btn">
            {{ 'Delete'|t('report-manager') }} (<span class="lr-bulk-count">0</span>)
        </button>
    {% endif %}
{% endblock %}


{# ============================================================================
   CUSTOM SCRIPTS
   ============================================================================ #}

{% block scripts %}
    <script>
    (function() {
        if (typeof Craft === 'undefined') return;

        // Initialise the "Set status" menubtn — without `new Craft.MenuBtn(...)`
        // clicking the button doesn't open its menu.
        const bulkStatusBtn = document.getElementById('lr-bulk-status-btn');
        if (bulkStatusBtn && Craft.MenuBtn) {
            new Craft.MenuBtn(bulkStatusBtn);
        }

        const T = {
            reportDeleted: {{ 'Report deleted.'|t('report-manager')|json_encode|raw }},
            deleteFailed: {{ 'Could not delete report.'|t('report-manager')|json_encode|raw }},
            deleteConfirmTemplate: {{ 'Delete report "{name}"? This cannot be undone.'|t('report-manager')|json_encode|raw }},
            generateQueued: {{ 'Export queued for generation.'|t('report-manager')|json_encode|raw }},
            generateFailed: {{ 'Could not queue export.'|t('report-manager')|json_encode|raw }},
            bulkEnabledTemplate: {{ 'Enabled {count} report(s).'|t('report-manager')|json_encode|raw }},
            bulkEnableFailed: {{ 'Could not enable reports.'|t('report-manager')|json_encode|raw }},
            bulkDisabledTemplate: {{ 'Disabled {count} report(s).'|t('report-manager')|json_encode|raw }},
            bulkDisableFailed: {{ 'Could not disable reports.'|t('report-manager')|json_encode|raw }},
            bulkDeletedTemplate: {{ 'Deleted {count} report(s).'|t('report-manager')|json_encode|raw }},
            bulkDeleteFailed: {{ 'Could not delete reports.'|t('report-manager')|json_encode|raw }},
            bulkDeleteConfirmTemplate: {{ 'Delete {count} report(s)? This cannot be undone.'|t('report-manager')|json_encode|raw }},
        };

        document.addEventListener('lr:selectionChanged', function(e) {
            const ids = (e.detail && Array.isArray(e.detail.selectedIds))
                ? e.detail.selectedIds
                : [];
            document.querySelectorAll('.lr-bulk-count').forEach(function(el) {
                el.textContent = ids.length;
            });
        });

        function selectedIds() {
            return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
        }

        // ---------------------------------------------------------------------
        // Row actions: delegated, anchor-scoped, action-allowlisted.
        // ---------------------------------------------------------------------
        document.addEventListener('click', function(e) {
            const trigger = e.target.closest('a[data-action]');
            if (!trigger) return;

            const action = trigger.dataset.action;
            if (action !== 'generate' && action !== 'delete') return;

            const reportId = parseInt(trigger.dataset.id || '0', 10);
            if (!reportId) return;
            e.preventDefault();

            const name = trigger.dataset.name || '';

            if (action === 'generate') {
                Craft.sendActionRequest('POST', 'report-manager/reports/generate', {
                    data: {reportId: reportId},
                }).then(function(response) {
                    if (response.data.success) {
                        Craft.cp.displayNotice(T.generateQueued);
                        setTimeout(function() {
                            window.location.href = Craft.getCpUrl('report-manager/reports/' + reportId + '/generated');
                        }, 500);
                    } else if (response.data.error) {
                        Craft.cp.displayError(response.data.error);
                    }
                }).catch(function() {
                    Craft.cp.displayError(T.generateFailed);
                });
            } else if (action === 'delete') {
                if (!confirm(T.deleteConfirmTemplate.replace('{name}', name))) return;
                Craft.sendActionRequest('POST', 'report-manager/reports/delete', {
                    data: {reportId: reportId},
                }).then(function(response) {
                    if (response.data.success) {
                        Craft.cp.displayNotice(T.reportDeleted);
                        setTimeout(function() { window.location.reload(); }, 500);
                    } else if (response.data.error) {
                        Craft.cp.displayError(response.data.error);
                    }
                }).catch(function() {
                    Craft.cp.displayError(T.deleteFailed);
                });
            }
        });

        // ---------------------------------------------------------------------
        // Bulk actions. Shared helper for the status-change endpoints.
        // ---------------------------------------------------------------------
        function runBulkStatus(endpoint, successTemplate, errorFallback) {
            const ids = selectedIds();
            if (!ids.length) return;
            Craft.sendActionRequest('POST', endpoint, {
                data: {reportIds: ids},
            }).then(function(response) {
                const count = response.data.count || 0;
                if (count > 0) {
                    Craft.cp.displayNotice(successTemplate.replace('{count}', count));
                }
                if (response.data.error) {
                    Craft.cp.displayError(response.data.error);
                }
                if (count > 0) {
                    setTimeout(function() { window.location.reload(); }, 1000);
                }
            }).catch(function() {
                Craft.cp.displayError(errorFallback);
            });
        }

        document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
            e.preventDefault();
            runBulkStatus('report-manager/reports/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
        });

        document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
            e.preventDefault();
            runBulkStatus('report-manager/reports/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
        });

        document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
            const ids = selectedIds();
            if (!ids.length) return;
            if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;
            runBulkStatus('report-manager/reports/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
        });
    })();
    </script>
{% endblock %}
