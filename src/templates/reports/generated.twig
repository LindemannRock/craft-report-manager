{#
 # Report Generated Files - Using cp-table layout
 #
 # Lists all generated export files for a specific report.
 # Sort/paginate are owned by ReportsController::actionGenerated.
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# ============================================================================
   TABLE CONFIGURATION
   ============================================================================ #}

{% set showActionsColumn = canDownload or canDelete %}

{% set tableConfig = {
    plugin: {
        handle: 'report-manager',
        name: reportHelper.fullName,
    },
    page: {
        title: report.name ~ ' - ' ~ 'Generated Files'|t('report-manager'),
        subnav: 'reports',
        crumbs: [
            { label: reportHelper.fullName, url: url('report-manager') },
            { label: 'Reports'|t('report-manager'), url: url('report-manager/reports') },
            { label: report.name, url: url('report-manager/reports/' ~ report.id) },
            { label: 'Generated Files'|t('report-manager') }
        ],
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: [
            {key: 'filename', label: 'Filename'|t('report-manager'), sortable: true},
            {key: 'format', label: 'Format'|t('report-manager'), sortable: true},
            {key: 'status', label: 'Status'|t('report-manager'), sortable: true},
            {key: 'recordCount', label: 'Records'|t('report-manager'), sortable: true},
            {key: 'fileSize', label: 'Size'|t('report-manager'), sortable: true},
            {key: 'dateCreated', label: 'Created'|t('report-manager'), sortable: true},
        ],
        items: exports,
        emptyMessage: 'No generated files yet.'|t('report-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'file'|t('report-manager'), plural: 'files'|t('report-manager')},
    },
    checkboxes: canDelete,
} %}


{# ============================================================================
   TOOLBAR ACTIONS
   ============================================================================ #}

{% block toolbarActions %}
    {% if canCreate %}
        <form method="post" action="" style="display: inline;">
            <input type="hidden" name="action" value="report-manager/reports/generate">
            <input type="hidden" name="reportId" value="{{ report.id }}">
            {{ csrfInput() }}
            <button type="submit" class="btn submit add icon">{{ 'Generate Now'|t('report-manager') }}</button>
        </form>
    {% endif %}
{% endblock %}


{# ============================================================================
   CUSTOM TABLE ROW RENDERING
   ============================================================================ #}

{% block tableRow %}
    {# Filename #}
    <td>
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% if item.isCompleted() and canDownload and fileAvailable %}
            <a href="{{ url('report-manager/exports/download/' ~ item.id) }}">{{ item.filename }}</a>
        {% else %}
            <span>{{ item.filename }}</span>
        {% endif %}
        {% if item.isCombinedExport() %}
            <span class="light">({{ 'Combined'|t('report-manager') }})</span>
        {% elseif item.entityName %}
            <br><span class="light">{{ item.entityName }}</span>
        {% endif %}
    </td>

    {# Format #}
    <td>{{ item.format|upper }}</td>

    {# Status #}
    <td>
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% set isMissingFile = item.isCompleted() and not fileAvailable %}
        {% include 'lindemannrock-base/_components/badge' with {
            label: isMissingFile ? 'Missing file'|t('report-manager') : item.statusLabel ~ (item.isProcessing() ? ' (' ~ item.progress ~ '%)' : ''),
            value: isMissingFile ? 'missing' : item.status,
            colorSet: 'exportStatus',
        } only %}
    </td>

    {# Records #}
    <td>{{ item.recordCount|number_format }}</td>

    {# Size #}
    <td>{{ item.formattedFileSize }}</td>

    {# Created #}
    <td class="light">{{ item.dateCreated|lrDatetime }}</td>
{% endblock %}


{# ============================================================================
   ROW ACTIONS
   ============================================================================ #}

{% block rowActions %}
    {% if showActionsColumn %}
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% set displayName = item.entityName ?: item.filename %}

        {% set actionItems = [
            {
                label: 'Details'|t('report-manager'),
                url: url('report-manager/exports/' ~ item.id),
            },
        ] %}

        {% if item.isCompleted() and canDownload and fileAvailable %}
            {% set actionItems = actionItems|merge([{
                label: 'Download'|t('report-manager'),
                url: url('report-manager/exports/download/' ~ item.id),
            }]) %}
        {% endif %}

        {% if canDelete %}
            {% set actionItems = actionItems|merge([
                {type: 'divider'},
                {
                    label: 'Delete'|t('report-manager'),
                    class: 'error',
                    jsAction: 'delete',
                    data: {name: displayName},
                },
            ]) %}
        {% endif %}

        {% include 'lindemannrock-base/_components/row-actions' with {
            item: item,
            actions: {
                type: 'menu',
                icon: 'settings',
                title: 'Actions'|t('report-manager'),
                items: actionItems,
            },
        } only %}
    {% endif %}
{% endblock %}


{# ============================================================================
   BULK ACTIONS
   ============================================================================ #}

{% block bulkActions %}
    {% if canDelete %}
        {% include 'lindemannrock-base/_components/bulk-actions-menu' with {
            label: 'Actions'|t('report-manager'),
            countId: 'lr-bulk-actions-count',
            items: [
                {id: 'lr-bulk-delete-btn', label: 'Delete'|t('report-manager'), class: 'error'},
            ],
        } only %}
    {% endif %}
{% endblock %}


{# ============================================================================
   SIDEBAR - Report Details
   ============================================================================ #}

{% block sidebarContent %}
    <dl class="meta read-only">
        <div class="data">
            <dt class="heading">{{ 'ID'|t('report-manager') }}</dt>
            <dd class="value">{{ report.id }}</dd>
        </div>
        <div class="data">
            <dt class="heading">{{ 'Report'|t('report-manager') }}</dt>
            <dd class="value"><a href="{{ url('report-manager/reports/' ~ report.id) }}">{{ report.name }}</a></dd>
        </div>
        <div class="data">
            <dt class="heading">{{ 'Status'|t('report-manager') }}</dt>
            <dd class="value">
                {% include 'lindemannrock-base/_components/status-dot' with {
                    value: report.enabled ? 'enabled' : 'disabled',
                    colorSet: 'status',
                } only %}
                <span>{{ report.enabled ? 'Enabled'|t('report-manager') : 'Disabled'|t('report-manager') }}</span>
            </dd>
        </div>
        <div class="data">
            <dt class="heading">{{ 'Format'|t('report-manager') }}</dt>
            <dd class="value">
                {% include 'lindemannrock-base/_components/status-dot' with {
                    value: report.exportFormat,
                    colorSet: 'exportFormat',
                } only %}
                <span>{{ report.exportFormat|upper }}</span>
            </dd>
        </div>
        <div class="data">
            <dt class="heading">{{ 'Export Mode'|t('report-manager') }}</dt>
            <dd class="value">{{ report.exportMode == 'combined' ? 'Combined File'|t('report-manager') : 'Separate Files'|t('report-manager') }}</dd>
        </div>
        <div class="data">
            <dt class="heading">{{ dataSourceLabels.entityPlural ?? 'Items'|t('report-manager') }}</dt>
            <dd class="value">{{ report.entityIdsArray|length }}</dd>
        </div>
        {% if report.lastGeneratedAt %}
            <div class="data">
                <dt class="heading">{{ 'Last Generated'|t('report-manager') }}</dt>
                <dd class="value">{{ report.lastGeneratedAt|lrDatetime }}</dd>
            </div>
        {% endif %}
        <div class="data">
            <dt class="heading">{{ 'Total Files'|t('report-manager') }}</dt>
            <dd class="value">{{ totalCount }}</dd>
        </div>
    </dl>
{% endblock %}


{# ============================================================================
   CUSTOM SCRIPTS
   ============================================================================ #}

{% block scripts %}
    <script>
    (function() {
        if (typeof Craft === 'undefined') return;

        const T = {
            fileDeleted: {{ 'File deleted.'|t('report-manager')|json_encode|raw }},
            deleteFailed: {{ 'Could not delete file.'|t('report-manager')|json_encode|raw }},
            deleteConfirmTemplate: {{ 'Delete "{name}"? This cannot be undone.'|t('report-manager')|json_encode|raw }},
            bulkDeletedTemplate: {{ 'Deleted {count} file(s).'|t('report-manager')|json_encode|raw }},
            bulkDeleteFailed: {{ 'Could not delete files.'|t('report-manager')|json_encode|raw }},
            bulkDeleteConfirmTemplate: {{ 'Delete {count} file(s)? This cannot be undone.'|t('report-manager')|json_encode|raw }},
        };

        function selectedIds() {
            return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
        }

        // Row actions: delegated, anchor-scoped, action-allowlisted.
        document.addEventListener('click', function(e) {
            const trigger = e.target.closest('a[data-action]');
            if (!trigger) return;

            const action = trigger.dataset.action;
            if (action !== 'delete') return;

            const exportId = parseInt(trigger.dataset.id || '0', 10);
            if (!exportId) return;
            e.preventDefault();

            const name = trigger.dataset.name || '';
            if (!confirm(T.deleteConfirmTemplate.replace('{name}', name))) return;

            Craft.sendActionRequest('POST', 'report-manager/exports/delete', {
                data: {id: exportId},
            }).then(function(response) {
                if (response.data.success) {
                    Craft.cp.displayNotice(T.fileDeleted);
                    setTimeout(function() { window.location.reload(); }, 500);
                } else if (response.data.error) {
                    Craft.cp.displayError(response.data.error);
                }
            }).catch(function() {
                Craft.cp.displayError(T.deleteFailed);
            });
        });

        // Bulk delete.
        document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
            const ids = selectedIds();
            if (!ids.length) return;
            if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;

            Craft.sendActionRequest('POST', 'report-manager/exports/bulk-delete', {
                data: {exportIds: ids},
            }).then(function(response) {
                if (response.data.success) {
                    const deleted = response.data.deleted || 0;
                    Craft.cp.displayNotice(T.bulkDeletedTemplate.replace('{count}', deleted));
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else if (response.data.error) {
                    Craft.cp.displayError(response.data.error);
                }
            }).catch(function() {
                Craft.cp.displayError(T.bulkDeleteFailed);
            });
        });
    })();
    </script>
{% endblock %}
