{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}
{% do view.registerAssetBundle('lindemannrock\\base\\web\\assets\\components\\ComponentsAsset') %}

{% set plugin = craft.app.plugins.getPlugin('report-manager') %}
{% set title = isNew ? 'New Report'|t('report-manager') : 'Edit Report'|t('report-manager') %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'reports' %}
{% set saveShortcutRedirect = cpUrl('report-manager/reports/{id}') %}
{% set retainScrollOnSaveShortcut = true %}
{% set dataSourceLabels = dataSourceLabels ?? {} %}
{% set tabs = {
    fields: {
        label: 'Settings'|t('report-manager'),
        url: '#fields',
    },
} %}

{% if not isNew and canAccessGeneratedFiles %}
    {% set tabs = tabs|merge({
        generatedFiles: {
            label: 'Generated Files'|t('report-manager'),
            url: '#generated-files',
        },
    }) %}
{% endif %}

{% set crumbs = [
    { label: reportHelper.fullName, url: url('report-manager') },
    { label: 'Reports'|t('report-manager'), url: url('report-manager/reports') },
    { label: isNew ? 'New Report'|t('report-manager') : report.name }
] %}

{# Get current entity IDs for checkboxes #}
{% set selectedEntityIds = report.entityIdsArray ?? [] %}

{% block actionButton %}
    <div class="btngroup submit">
        <button type="submit" class="btn submit">{{ 'Save'|t('report-manager') }}</button>
        <button type="button" class="btn submit menubtn"></button>
        <div class="menu">
            <ul role="listbox">
                <li>
                    <a class="formsubmit" role="option" tabindex="0" data-redirect="{{ cpUrl('report-manager/reports/{id}')|hash }}">
                        <span class="label">{{ 'Save and continue editing'|t('report-manager') }}</span>
                        <span class="shortcut" id="save-shortcut"></span>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    {% if not isNew and currentUser.can('reportManager:manageReports') %}
        <button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('report-manager') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('report-manager') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
        <div id="action-menu" class="menu menu--disclosure">
            <ul>
                <li>
                    <button class="menu-item error formsubmit" data-destructive data-action="report-manager/reports/delete" data-params='{"id":{{ report.id }}}' data-confirm="{{ 'Are you sure you want to delete this report?'|t('report-manager') }}" data-redirect="{{ 'report-manager/reports'|hash }}" data-headers='{"Accept":"application/json"}'>
                        <span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
                        <span class="menu-item-label">{{ 'Delete'|t('report-manager') }}</span>
                    </button>
                </li>
            </ul>
        </div>
    {% endif %}
{% endblock %}

{# Validation errors summary — rendered above the form by the cp layout #}
{% if report.hasErrors() %}
    {% set errorSummary %}
        {% include 'lindemannrock-base/_partials/error-summary' with {
            errors: report.getErrors(),
            linkMode: 'field-id',
            translationCategory: 'report-manager'
        } %}
    {% endset %}
{% endif %}

{% block content %}
    <input type="hidden" name="action" value="report-manager/reports/save">
    <input type="hidden" name="redirect" value="{{ 'report-manager/reports'|hash }}">
    {% if not isNew %}
        <input type="hidden" name="reportId" value="{{ report.id }}">
    {% endif %}
    {{ csrfInput() }}

    <div id="fields">
        {{ forms.textField({
            first: true,
            label: 'Name'|t('report-manager'),
            instructions: 'A descriptive name for this report.'|t('report-manager'),
            id: 'name',
            name: 'name',
            value: report.name,
            required: true,
            errors: report.getErrors('name')
        }) }}

        {{ forms.textField({
            label: 'Handle'|t('report-manager'),
            instructions: 'A unique identifier for this report.'|t('report-manager'),
            id: 'handle',
            name: 'handle',
            class: 'code',
            value: report.handle,
            errors: report.getErrors('handle')
        }) }}

        {{ forms.textareaField({
            label: 'Description'|t('report-manager'),
            instructions: 'Optional description for this report.'|t('report-manager'),
            id: 'description',
            name: 'description',
            value: report.description,
            rows: 3,
            errors: report.getErrors('description')
        }) }}

        <hr>

        {{ forms.selectField({
            label: 'Data Source'|t('report-manager'),
            instructions: 'Select the data source for this report.'|t('report-manager'),
            id: 'dataSource',
            name: 'dataSource',
            value: report.dataSource ?? dataSourceOptions|first.value ?? '',
            options: dataSourceOptions,
            required: true,
            errors: report.getErrors('dataSource')
        }) }}

        {# Explains, per data source, what gets exported and how the date range filters it #}
        {% include 'lindemannrock-base/_components/info-box' with {
            message: dataSourceLabels.dateFilterInfo ?? 'Records are included when their Filter by date value falls within the Date Range.'|t('report-manager'),
            type: 'info',
            margin: 'none',
            messageId: 'dateFilterInfo-message',
        } only %}

        {% if siteOptions|length > 0 %}
            {{ forms.checkboxGroupField({
                label: 'Sites'|t('report-manager'),
                instructions: 'Which sites to export (leave all unchecked to export all sites)'|t('report-manager'),
                id: 'siteIds',
                name: 'siteIds',
                values: report.getSiteIdsArray(),
                options: siteOptions
            }) }}
        {% endif %}

        {% set entityOptions = [] %}
        {% for entity in entities %}
            {% set recordCount = entity.recordCount ?? entity.submissionCount ?? 0 %}
            {% set recordLabel = entity.recordLabel ?? dataSourceLabels.recordPlural ?? 'records'|t('report-manager') %}
            {% set entityOptions = entityOptions|merge([{
                label: entity.name ~ ' - (' ~ recordCount|number ~ ' ' ~ recordLabel ~ ')',
                value: entity.id,
            }]) %}
        {% endfor %}

        {{ forms.checkboxGroupField({
            label: dataSourceLabels.entitySelectionLabel ?? 'Items to Export'|t('report-manager'),
            instructions: dataSourceLabels.entitySelectionInstructions ?? 'Select one or more items to include in this report.'|t('report-manager'),
            id: 'entityIds',
            name: 'entityIds',
            values: selectedEntityIds,
            options: entityOptions,
            required: true,
            errors: report.getErrors('entityIds'),
        }) }}

        <p class="light{{ entities|length > 0 ? ' hidden' : '' }}" id="entities-empty-message">{{ dataSourceLabels.emptyEntitiesMessage ?? 'No items available.'|t('report-manager') }}</p>

    </div>

    {% if not isNew and canAccessGeneratedFiles %}
        <div id="generated-files" class="hidden">
            {% include 'report-manager/reports/_partials/generated-files' with {
                report: report,
                exports: generatedExports,
                exportFileExists: generatedExportFileExists,
                totalCount: generatedExportsTotalCount,
                canDownload: currentUser.can('reportManager:downloadExports'),
            } only %}
        </div>
    {% endif %}
{% endblock %}

{% block details %}
    <div class="meta">
        {{ forms.lightswitchField({
            label: 'Enabled'|t('report-manager'),
            id: 'enabled',
            name: 'enabled',
            on: report.enabled ?? true
        }) }}

        {{ forms.selectField({
            label: 'Filter by date'|t('report-manager'),
            instructions: 'Which date the Date Range filters on.'|t('report-manager'),
            id: 'dateField',
            name: 'dateField',
            value: report.dateField,
            options: dateFieldOptions,
            errors: report.getErrors('dateField')
        }) }}

        {{ forms.selectField({
            label: 'Date Range'|t('report-manager'),
            id: 'dateRange',
            name: 'dateRange',
            value: report.dateRange,
            options: dateRangeOptions,
            errors: report.getErrors('dateRange')
        }) }}

        {{ forms.dateField({
            label: 'Start Date'|t('report-manager'),
            id: 'customDateStart',
            name: 'customDateStart',
            value: report.customDateStart,
            errors: report.getErrors('customDateStart'),
            fieldId: 'customDateStart-field',
            fieldClass: report.dateRange == 'custom' ? '' : 'hidden'
        }) }}

        {{ forms.dateField({
            label: 'End Date'|t('report-manager'),
            id: 'customDateEnd',
            name: 'customDateEnd',
            value: report.customDateEnd,
            errors: report.getErrors('customDateEnd'),
            fieldId: 'customDateEnd-field',
            fieldClass: report.dateRange == 'custom' ? '' : 'hidden'
        }) }}

        {{ forms.selectField({
            label: 'Format'|t('report-manager'),
            id: 'exportFormat',
            name: 'exportFormat',
            value: report.exportFormat,
            options: exportFormatOptions,
            errors: report.getErrors('exportFormat')
        }) }}

        {{ forms.selectField({
            label: 'Mode'|t('report-manager'),
            id: 'exportMode',
            name: 'exportMode',
            value: report.exportMode ?? 'separate',
            options: [
                { value: 'separate', label: 'Separate Files'|t('report-manager') },
                { value: 'combined', label: 'Combined File'|t('report-manager') }
            ],
            errors: report.getErrors('exportMode')
        }) }}

        {% if settings.enableScheduledReports %}
            {{ forms.lightswitchField({
                label: 'Scheduled'|t('report-manager'),
                id: 'enableSchedule',
                name: 'enableSchedule',
                on: report.enableSchedule ?? false,
                toggle: 'schedule-field'
            }) }}

            {{ forms.selectField({
                label: 'Frequency'|t('report-manager'),
                id: 'schedule',
                name: 'schedule',
                value: report.schedule,
                options: scheduleOptions|filter(o => o.value != 'disabled'),
                errors: report.getErrors('schedule'),
                fieldId: 'schedule-field',
                fieldClass: (report.enableSchedule ?? false) ? '' : 'hidden'
            }) }}
        {% endif %}

        {% if not isNew %}
            <div class="field" style="margin-top: 15px;">
                <div class="heading">
                    <label>{{ 'Actions'|t('report-manager') }}</label>
                </div>
                <div class="input">
                    <div class="btngroup">
                        <button type="button" class="btn menubtn" data-icon="settings">{{ 'Report Actions'|t('report-manager') }}</button>
                        <div class="menu">
                            <ul>
                                <li><a id="generate-now-btn" href="#">{{ 'Generate Now'|t('report-manager') }}</a></li>
                                <li><a href="{{ url('report-manager/reports/' ~ report.id ~ '/generated') }}">{{ 'View Generated'|t('report-manager') }}</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    {% if not isNew %}
        <dl class="meta read-only">
            <div class="data">
                <dt class="heading">{{ 'ID'|t('report-manager') }}</dt>
                <dd class="value">{{ report.id }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ 'Status'|t('report-manager') }}</dt>
                <dd class="value">
                    {% include 'lindemannrock-base/_components/status-dot' with {
                        value: report.enabled ? 'enabled' : 'disabled',
                        colorSet: 'status',
                    } only %}
                    <span>{{ report.enabled ? 'Enabled'|t('report-manager') : 'Disabled'|t('report-manager') }}</span>
                </dd>
            </div>
            <div class="data">
                <dt class="heading">{{ 'Format'|t('report-manager') }}</dt>
                <dd class="value">
                    {% include 'lindemannrock-base/_components/status-dot' with {
                        value: report.exportFormat,
                        colorSet: 'exportFormat',
                    } only %}
                    <span>{{ report.exportFormat|upper }}</span>
                </dd>
            </div>
            <div class="data">
                <dt class="heading">{{ 'Mode'|t('report-manager') }}</dt>
                <dd class="value">{{ report.exportMode == 'combined' ? 'Combined'|t('report-manager') : 'Separate'|t('report-manager') }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ dataSourceLabels.entityPlural ?? 'Items'|t('report-manager') }}</dt>
                <dd class="value">{{ report.entityIdsArray|length }}</dd>
            </div>
            {% if report.lastGeneratedAt %}
                <div class="data">
                    <dt class="heading">{{ 'Last Generated'|t('report-manager') }}</dt>
                    <dd class="value">{{ report.lastGeneratedAt|lrDatetime }}</dd>
                </div>
            {% endif %}
            {% if settings.enableScheduledReports and report.enableSchedule and report.nextScheduledAt %}
                <div class="data">
                    <dt class="heading">{{ 'Next Scheduled'|t('report-manager') }}</dt>
                    <dd class="value">{{ report.nextScheduledAt|lrDatetime }}</dd>
                </div>
            {% endif %}
            <div class="data">
                <dt class="heading">{{ 'Created at'|t('report-manager') }}</dt>
                <dd class="value">{{ report.dateCreated|lrDatetime }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ 'Updated at'|t('report-manager') }}</dt>
                <dd class="value">{{ report.dateUpdated|lrDatetime }}</dd>
            </div>
        </dl>
    {% endif %}
{% endblock %}

{% js %}
window.lrIdentifiers?.bindSlugHandle('#name', '#handle', {
    isNew: {{ isNew ? 'true' : 'false' }},
});

// Set platform-specific keyboard shortcut
const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
const saveShortcut = document.getElementById('save-shortcut');
if (saveShortcut) {
    saveShortcut.textContent = isMac ? '⌘S' : 'Ctrl+S';
}

// Toggle custom date range visibility
$('#dateRange').on('change', function() {
    var isCustom = $(this).val() === 'custom';
    $('#customDateStart-field, #customDateEnd-field').toggleClass('hidden', !isCustom);
});

// Live check: warn the moment an inverted range is picked (start after end),
// which would silently produce an empty export. The server enforces the same
// rule on save (ReportRecord::validateCustomDateRange) — this is just faster feedback.
var customRangeErrorMsg = {{ 'End date must be on or after the start date.'|t('report-manager')|json_encode|raw }};

function getPickerDate($input) {
    return $input.hasClass('hasDatepicker') ? $input.datepicker('getDate') : null;
}

function validateCustomDateRange() {
    var $start = $('#customDateStart');
    var $end = $('#customDateEnd');
    if (!$start.length || !$end.length) {
        return;
    }

    var start = getPickerDate($start);
    var end = getPickerDate($end);
    var $field = $('#customDateEnd-field');
    var $error = $('#customDateEnd-range-error');

    if (start && end && start > end) {
        if (!$error.length) {
            $error = $('<ul class="errors" id="customDateEnd-range-error"><li></li></ul>');
            $field.addClass('has-errors').append($error);
        }
        $error.find('li').text(customRangeErrorMsg);
    } else {
        $error.remove();
        $field.removeClass('has-errors');
    }
}

$('#customDateStart, #customDateEnd').on('change', validateCustomDateRange);


const fallbackDataSourceLabels = {{ dataSourceLabels|json_encode|raw }};

function getDataSourceLabel(labels, key, fallback) {
    return labels && labels[key] ? labels[key] : fallback;
}

function appendEntityLabel($label, entity, labels) {
    var recordCount = entity.recordCount ?? entity.submissionCount ?? 0;
    var recordLabel = entity.recordLabel || getDataSourceLabel(labels, 'recordPlural', '{{ 'records'|t('report-manager')|e('js') }}');

    $label.text(entity.name + ' - (' + recordCount + ' ' + recordLabel + ')');
}

// Load entities when data source changes
$('#dataSource').on('change', function() {
    var dataSource = $(this).val();
    if (!dataSource) return;

    $.ajax({
        url: Craft.getCpUrl('report-manager/api/entities/' + dataSource),
        type: 'GET',
        dataType: 'json',
        success: function(response) {
            var $container = $('#entityIds');
            var $emptyMessage = $('#entities-empty-message');
            var labels = response.labels || fallbackDataSourceLabels;

            // Update "Filter by date" options + the per-source info box
            var $dateField = $('#dateField');
            if ($dateField.length && response.dateFieldOptions) {
                var currentDateField = $dateField.val();
                var dateFieldValues = response.dateFieldOptions.map(function(o) { return o.value; });
                $dateField.empty();
                response.dateFieldOptions.forEach(function(o) {
                    $dateField.append($('<option>').attr('value', o.value).text(o.label));
                });
                $dateField.val(dateFieldValues.indexOf(currentDateField) !== -1 ? currentDateField : response.defaultDateField);
            }
            $('#dateFilterInfo-message').text(getDataSourceLabel(labels, 'dateFilterInfo', ''));

            $container.empty();

            // The heading is a <legend> for checkbox groups (not a <label>); update only its
            // text node so the required-indicator span is preserved.
            var headingLabel = getDataSourceLabel(labels, 'entitySelectionLabel', '{{ 'Items to Export'|t('report-manager')|e('js') }}');
            var $heading = $('#entityIds-field .heading').children('legend, label');
            var $headingText = $heading.contents().filter(function() {
                return this.nodeType === 3;
            }).first();
            if ($headingText.length) {
                $headingText[0].textContent = headingLabel;
            } else {
                $heading.prepend(document.createTextNode(headingLabel));
            }
            $('#entityIds-field .instructions p').text(getDataSourceLabel(labels, 'entitySelectionInstructions', '{{ 'Select one or more items to include in this report.'|t('report-manager')|e('js') }}'));
            $container.append($('<input type="hidden" name="entityIds" value="">'));

            if (!response.success || response.entities.length === 0) {
                $emptyMessage.text(getDataSourceLabel(labels, 'emptyEntitiesMessage', '{{ 'No items available.'|t('report-manager')|e('js') }}')).removeClass('hidden');
                return;
            }

            $emptyMessage.addClass('hidden');

            response.entities.forEach(function(entity) {
                var id = 'entityIds-' + entity.id;
                var $wrapper = $('<div>');
                var $checkbox = $('<input type="checkbox" class="checkbox" name="entityIds[]" value="' + entity.id + '">').attr('id', id);
                var $label = $('<label>').attr('for', id).attr('id', id + '-label');

                appendEntityLabel($label, entity, labels);
                $wrapper.append($checkbox);
                $wrapper.append($label);
                $container.append($wrapper);
            });
        }
    });
});

{% if not isNew %}
// Generate Now action - separate POST request
$('#generate-now-btn').on('click', function(e) {
    e.preventDefault();
    Craft.sendActionRequest('POST', 'report-manager/reports/generate', {
        data: { reportId: {{ report.id }} }
    }).then(function(response) {
        window.location.href = Craft.getCpUrl('report-manager/reports/{{ report.id }}/generated');
    }).catch(function(error) {
        Craft.cp.displayError({{ 'Could not generate export.'|t('report-manager')|json_encode|raw }});
    });
});
{% endif %}
{% endjs %}
