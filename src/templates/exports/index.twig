{#
 # Exports Index - Using cp-table layout
 #
 # Lists all exports with filtering, sorting, bulk actions and pagination.
 # Filters/sort/paginate are owned by ExportsController::actionIndex.
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{# ============================================================================
   BUILD FILTER OPTIONS
   ============================================================================ #}

{% set statusOptions = [
    {value: 'all', label: 'All'|t('report-manager'), status: 'all'},
    {value: 'pending', label: 'Pending'|t('report-manager'), colorKey: 'pending'},
    {value: 'processing', label: 'Processing'|t('report-manager'), colorKey: 'processing'},
    {value: 'completed', label: 'Completed'|t('report-manager'), colorKey: 'completed'},
    {value: 'failed', label: 'Failed'|t('report-manager'), colorKey: 'failed'},
] %}

{# Build format options from enabled exports config. #}
{% set formatOptions = [{value: 'all', label: 'All Formats'|t('report-manager')}] %}
{% for format in lrExportFormatOptions() %}
    {% set formatOptions = formatOptions|merge([{value: format.value, label: format.label}]) %}
{% endfor %}

{# ============================================================================
   TABLE CONFIGURATION
   ============================================================================ #}

{% set showActionsColumn = canDownload or canDelete %}

{% set tableConfig = {
    plugin: {
        handle: 'report-manager',
        name: reportHelper.fullName,
    },
    page: {
        title: 'Exports'|t('report-manager'),
        subnav: 'exports',
        crumbs: [
            { label: reportHelper.fullName, url: url('report-manager') },
            { label: 'Exports'|t('report-manager') }
        ],
    },
    filters: [
        {
            type: 'status',
            param: 'status',
            current: statusFilter,
            label: statusFilter == 'all' ? 'All'|t('report-manager') : statusFilter|capitalize,
            colorSet: 'exportStatus',
            options: statusOptions,
        },
        {
            type: 'dropdown',
            param: 'format',
            current: formatFilter,
            label: formatFilter == 'all' ? 'All Formats'|t('report-manager') : formatFilter|upper,
            options: formatOptions,
        },
    ],
    search: {
        placeholder: 'Search exports...'|t('report-manager'),
        value: search,
    },
    sort: {
        field: sort,
        direction: dir,
    },
    table: {
        columns: [
            {key: 'entityName', label: 'Name'|t('report-manager'), sortable: true},
            {key: 'format', label: 'Format'|t('report-manager'), sortable: true},
            {key: 'status', label: 'Status'|t('report-manager'), sortable: true},
            {key: 'recordCount', label: 'Records'|t('report-manager'), sortable: true},
            {key: 'fileSize', label: 'Size'|t('report-manager'), sortable: true},
            {key: 'triggeredBy', label: 'Type'|t('report-manager'), sortable: true},
            {key: 'dateCreated', label: 'Created'|t('report-manager'), sortable: true},
        ],
        items: exports,
        emptyMessage: 'No exports found.'|t('report-manager'),
    },
    pagination: {
        page: page,
        limit: limit,
        totalCount: totalCount,
        itemLabel: {singular: 'export'|t('report-manager'), plural: 'exports'|t('report-manager')},
    },
    checkboxes: canDelete,
    newButton: canCreate ? {
        url: url('report-manager/exports/new'),
        label: 'Quick Export'|t('report-manager'),
    } : null,
} %}


{# ============================================================================
   CUSTOM TABLE ROW RENDERING
   ============================================================================ #}

{% block tableRow %}
    {# Name #}
    <td>
        {% set displayName = item.filename ?? ('Export #' ~ item.id) %}
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% if item.isCompleted() and canDownload and fileAvailable %}
            <a href="{{ url('report-manager/exports/download/' ~ item.id) }}">
                <strong>{{ displayName }}</strong>
            </a>
        {% else %}
            <strong>{{ displayName }}</strong>
        {% endif %}
    </td>

    {# Format #}
    <td>{{ item.format|upper }}</td>

    {# Status #}
    <td>
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% set isMissingFile = item.isCompleted() and not fileAvailable %}
        {% include 'lindemannrock-base/_components/badge' with {
            label: isMissingFile ? 'Missing file'|t('report-manager') : item.statusLabel ~ (item.isProcessing() ? ' (' ~ item.progress ~ '%)' : ''),
            value: isMissingFile ? 'missing' : item.status,
            colorSet: 'exportStatus',
        } only %}
    </td>

    {# Records #}
    <td>{{ item.recordCount|number_format }}</td>

    {# Size #}
    <td>{{ item.formattedFileSize }}</td>

    {# Triggered By #}
    <td><span class="light">{{ item.triggerLabel }}</span></td>

    {# Created #}
    <td class="light">{{ item.dateCreated|lrCompactDatetime }}</td>
{% endblock %}


{# ============================================================================
   ROW ACTIONS
   ============================================================================ #}

{% block rowActions %}
    {% if showActionsColumn %}
        {% set fileAvailable = exportFileExists[item.id] ?? false %}
        {% if item.isCombinedExport() %}
            {% set displayName = 'Combined Export'|t('report-manager') ~ ' (' ~ item.getEntityIdsArray()|length ~ ' forms)' %}
        {% else %}
            {% set displayName = item.entityName ?? ('Export #' ~ item.id) %}
        {% endif %}

        {% set actionItems = [
            {
                label: 'Details'|t('report-manager'),
                url: url('report-manager/exports/' ~ item.id),
            },
        ] %}

        {% if item.isCompleted() and canDownload and fileAvailable %}
            {% set actionItems = actionItems|merge([{
                label: 'Download'|t('report-manager'),
                url: url('report-manager/exports/download/' ~ item.id),
            }]) %}
        {% endif %}

        {% if canDelete %}
            {% set actionItems = actionItems|merge([
                {type: 'divider'},
                {
                    label: 'Delete'|t('report-manager'),
                    class: 'error',
                    jsAction: 'delete',
                    data: {name: displayName},
                },
            ]) %}
        {% endif %}

        {% include 'lindemannrock-base/_components/row-actions' with {
            item: item,
            actions: {
                type: 'menu',
                icon: 'settings',
                title: 'Actions'|t('report-manager'),
                items: actionItems,
            },
        } only %}
    {% endif %}
{% endblock %}


{# ============================================================================
   BULK ACTIONS
   ============================================================================ #}

{% block bulkActions %}
    {% if canDelete %}
        <button type="button" class="btn secondary" id="lr-bulk-delete-btn">
            {{ 'Delete'|t('report-manager') }} (<span class="lr-bulk-count">0</span>)
        </button>
    {% endif %}
{% endblock %}


{# ============================================================================
   CUSTOM SCRIPTS
   ============================================================================ #}

{% block scripts %}
    <script>
    (function() {
        if (typeof Craft === 'undefined') return;

        const T = {
            exportDeleted: {{ 'Export deleted.'|t('report-manager')|json_encode|raw }},
            deleteFailed: {{ 'Could not delete export.'|t('report-manager')|json_encode|raw }},
            deleteConfirmTemplate: {{ 'Delete export "{name}"? This cannot be undone.'|t('report-manager')|json_encode|raw }},
            bulkDeletedTemplate: {{ 'Deleted {count} export(s).'|t('report-manager')|json_encode|raw }},
            bulkDeleteFailed: {{ 'Could not delete exports.'|t('report-manager')|json_encode|raw }},
            bulkDeleteConfirmTemplate: {{ 'Delete {count} export(s)? This cannot be undone.'|t('report-manager')|json_encode|raw }},
        };

        document.addEventListener('lr:selectionChanged', function(e) {
            const ids = (e.detail && Array.isArray(e.detail.selectedIds))
                ? e.detail.selectedIds
                : [];
            document.querySelectorAll('.lr-bulk-count').forEach(function(el) {
                el.textContent = ids.length;
            });
        });

        function selectedIds() {
            return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
        }

        // Row actions: delegated listener on document, scoped by anchor + allowlist.
        document.addEventListener('click', function(e) {
            const trigger = e.target.closest('a[data-action]');
            if (!trigger) return;

            const action = trigger.dataset.action;
            if (action !== 'delete') return;

            const exportId = parseInt(trigger.dataset.id || '0', 10);
            if (!exportId) return;
            e.preventDefault();

            const name = trigger.dataset.name || '';
            if (!confirm(T.deleteConfirmTemplate.replace('{name}', name))) return;

            Craft.sendActionRequest('POST', 'report-manager/exports/delete', {
                data: {id: exportId},
            }).then(function(response) {
                if (response.data.success) {
                    Craft.cp.displayNotice(T.exportDeleted);
                    setTimeout(function() { window.location.reload(); }, 500);
                } else if (response.data.error) {
                    Craft.cp.displayError(response.data.error);
                }
            }).catch(function() {
                Craft.cp.displayError(T.deleteFailed);
            });
        });

        // Bulk delete.
        document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
            const ids = selectedIds();
            if (!ids.length) return;
            if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;

            Craft.sendActionRequest('POST', 'report-manager/exports/bulk-delete', {
                data: {exportIds: ids},
            }).then(function(response) {
                if (response.data.success) {
                    const deleted = response.data.deleted || 0;
                    Craft.cp.displayNotice(T.bulkDeletedTemplate.replace('{count}', deleted));
                    setTimeout(function() { window.location.reload(); }, 1000);
                } else if (response.data.error) {
                    Craft.cp.displayError(response.data.error);
                }
            }).catch(function() {
                Craft.cp.displayError(T.bulkDeleteFailed);
            });
        });
    })();
    </script>
{% endblock %}
