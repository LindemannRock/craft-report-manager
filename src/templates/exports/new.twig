{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set plugin = craft.app.plugins.getPlugin('report-manager') %}
{% set title = 'Quick Export'|t('report-manager') %}
{% set fullPageForm = true %}
{% set selectedSubnavItem = 'exports' %}

{% set crumbs = [
    { label: reportHelper.fullName, url: url('report-manager') },
    { label: 'Exports'|t('report-manager'), url: url('report-manager/exports') },
    { label: 'Quick Export'|t('report-manager') }
] %}

{# Determine default data source and entities #}
{% set defaultDataSource = dataSourceOptions|first.value ?? '' %}
{% set currentEntities = allEntities[defaultDataSource].entities ?? [] %}
{% set dataSourceLabels = allEntities[defaultDataSource].labels ?? {} %}

{% block actionButton %}
    <div class="btngroup submit">
        <button type="submit" class="btn submit">{{ 'Generate Export'|t('report-manager') }}</button>
    </div>
{% endblock %}

{% block content %}
    <input type="hidden" name="action" value="report-manager/exports/quick-export">
    <input type="hidden" name="redirect" value="{{ 'report-manager/exports'|hash }}">
    {{ csrfInput() }}

    <div id="fields">
        {{ forms.selectField({
            first: true,
            label: 'Data Source'|t('report-manager'),
            instructions: 'Select the data source to export from.'|t('report-manager'),
            id: 'dataSource',
            name: 'dataSource',
            value: defaultDataSource,
            options: dataSourceOptions,
            required: true
        }) }}

        <div class="field" id="forms-field">
            <div class="heading">
                <label id="entity-selection-label">{{ dataSourceLabels.entitySelectionLabel ?? 'Items to Export'|t('report-manager') }}</label>
                <div class="instructions">
                    <p id="entity-selection-instructions">{{ dataSourceLabels.quickExportEntitySelectionInstructions ?? 'Select one or more items to export. Each item will generate a separate export file.'|t('report-manager') }}</p>
                </div>
            </div>
            <div class="input ltr">
                <div class="btngroup small" style="margin-bottom: 10px;">
                    <button type="button" class="btn small" id="select-all-forms">{{ 'Select All'|t('report-manager') }}</button>
                    <button type="button" class="btn small" id="select-none-forms">{{ 'Select None'|t('report-manager') }}</button>
                </div>
                <div id="forms-container">
                    {% for entity in currentEntities %}
                        {% set recordCount = entity.recordCount ?? entity.submissionCount ?? 0 %}
                        {% set recordLabel = entity.recordLabel ?? dataSourceLabels.recordPlural ?? 'records'|t('report-manager') %}
                        <div class="checkbox-wrapper" style="margin-bottom: 8px;">
                            <label>
                                <input type="checkbox" name="entityIds[]" value="{{ entity.id }}">
                                <strong>{{ entity.name }}</strong>
                                <span class="light">({{ recordCount }} {{ recordLabel }})</span>
                            </label>
                        </div>
                    {% else %}
                        <p class="light">{{ dataSourceLabels.emptyEntitiesMessage ?? 'No items available.'|t('report-manager') }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <hr>

        {{ forms.selectField({
            label: 'Date Range'|t('report-manager'),
            instructions: dataSourceLabels.dateRangeInstructions ?? 'Filter records by date range.'|t('report-manager'),
            id: 'dateRange',
            name: 'dateRange',
            value: settings.defaultDateRange,
            options: dateRangeOptions
        }) }}

        <div id="custom-date-range" style="display: none;">
            {{ forms.dateField({
                label: 'Start Date'|t('report-manager'),
                id: 'customDateStart',
                name: 'customDateStart'
            }) }}

            {{ forms.dateField({
                label: 'End Date'|t('report-manager'),
                id: 'customDateEnd',
                name: 'customDateEnd'
            }) }}
        </div>
    </div>
{% endblock %}

{% block details %}
    <div class="meta">
        {{ forms.selectField({
            label: 'Export Mode'|t('report-manager'),
            instructions: dataSourceLabels.exportModeInstructions ?? 'How to handle multiple items.'|t('report-manager'),
            id: 'exportMode',
            name: 'exportMode',
            value: 'separate',
            options: [
                { value: 'separate', label: 'Separate Files'|t('report-manager') },
                { value: 'combined', label: 'Combined File'|t('report-manager') },
            ]
        }) }}

        {{ forms.selectField({
            label: 'Export Format'|t('report-manager'),
            id: 'format',
            name: 'format',
            value: settings.defaultExportFormat,
            options: exportFormatOptions
        }) }}

        {{ forms.lightswitchField({
            label: 'Process Immediately'|t('report-manager'),
            instructions: 'Generate now instead of queuing.'|t('report-manager'),
            id: 'processImmediately',
            name: 'processImmediately',
            on: false
        }) }}

        {% if craft.app.getIsMultiSite() %}
            {% set siteOptions = [] %}
            {% for site in craft.app.sites.getAllSites() %}
                {% set siteOptions = siteOptions|merge([{ value: site.id, label: site.name }]) %}
            {% endfor %}
            {{ forms.checkboxGroupField({
                label: 'Sites'|t('report-manager'),
                instructions: 'Which sites to export (leave all unchecked to export all sites)'|t('report-manager'),
                id: 'siteIds',
                name: 'siteIds',
                options: siteOptions,
                values: []
            }) }}
        {% endif %}
    </div>

    <fieldset>
        <dl class="meta read-only">
            <div class="data">
                <dt class="heading" id="selected-entities-label">{{ dataSourceLabels.selectedEntitiesLabel ?? 'Selected Items'|t('report-manager') }}</dt>
                <dd class="value" id="selected-count">0</dd>
            </div>
        </dl>
    </fieldset>
{% endblock %}

{% js %}
// Store all entities data for JavaScript access
var allEntitiesData = {{ allEntities|json_encode|raw }};

function getDataSourceLabel(labels, key, fallback) {
    return labels && labels[key] ? labels[key] : fallback;
}

function appendEntityLabel($label, entity, labels) {
    var recordCount = entity.recordCount ?? entity.submissionCount ?? 0;
    var recordLabel = entity.recordLabel || getDataSourceLabel(labels, 'recordPlural', '{{ 'records'|t('report-manager')|e('js') }}');

    $label.append(' ');
    $label.append($('<strong>').text(entity.name));
    $label.append(' ');
    $label.append($('<span class="light">').text('(' + recordCount + ' ' + recordLabel + ')'));
}

// Update selected count
function updateSelectedCount() {
    var count = $('input[name="entityIds[]"]:checked').length;
    $('#selected-count').text(count);
}

// Select all/none buttons
$('#select-all-forms').on('click', function() {
    $('input[name="entityIds[]"]').prop('checked', true);
    updateSelectedCount();
});

$('#select-none-forms').on('click', function() {
    $('input[name="entityIds[]"]').prop('checked', false);
    updateSelectedCount();
});

// Update count when checkboxes change
$(document).on('change', 'input[name="entityIds[]"]', function() {
    updateSelectedCount();
});

// Toggle custom date range visibility
$('#dateRange').on('change', function() {
    if ($(this).val() === 'custom') {
        $('#custom-date-range').slideDown();
    } else {
        $('#custom-date-range').slideUp();
    }
});

// Load entities when data source changes
$('#dataSource').on('change', function() {
    var dataSource = $(this).val();
    var $container = $('#forms-container');
    $container.empty();

    if (dataSource && allEntitiesData[dataSource]) {
        var labels = allEntitiesData[dataSource].labels || {};
        var entities = allEntitiesData[dataSource].entities || [];

        $('#entity-selection-label').text(getDataSourceLabel(labels, 'entitySelectionLabel', '{{ 'Items to Export'|t('report-manager')|e('js') }}'));
        $('#entity-selection-instructions').text(getDataSourceLabel(labels, 'quickExportEntitySelectionInstructions', '{{ 'Select one or more items to export. Each item will generate a separate export file.'|t('report-manager')|e('js') }}'));
        $('#selected-entities-label').text(getDataSourceLabel(labels, 'selectedEntitiesLabel', '{{ 'Selected Items'|t('report-manager')|e('js') }}'));

        if (entities.length === 0) {
            $container.html($('<p class="light">').text(getDataSourceLabel(labels, 'emptyEntitiesMessage', '{{ 'No items available.'|t('report-manager')|e('js') }}')));
            updateSelectedCount();
            return;
        }

        entities.forEach(function(entity) {
            var $wrapper = $('<div class="checkbox-wrapper" style="margin-bottom: 8px;">');
            var $label = $('<label>');
            var $checkbox = $('<input type="checkbox" name="entityIds[]" value="' + entity.id + '">');

            $label.append($checkbox);
            appendEntityLabel($label, entity, labels);
            $wrapper.append($label);
            $container.append($wrapper);
        });
    } else {
        $container.html($('<p class="light">').text('{{ 'No items available.'|t('report-manager')|e('js') }}'));
    }

    updateSelectedCount();
});

// Initial count
updateSelectedCount();
{% endjs %}
